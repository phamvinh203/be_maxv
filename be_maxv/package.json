{
  "name": "be_maxv",
  "version": "1.0.0",
  "description": "Backend maxv_v2 - control plane (maxv2_sys) + provisioning DB tenant",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "generate": "prisma generate --schema=prisma/sys/schema.prisma && prisma generate --schema=prisma/tenant/schema.prisma",
    "migrate:sys": "dotenv -e .env.local -- prisma migrate dev --schema=prisma/sys/schema.prisma",
    "migrate:sys:deploy": "dotenv -e .env.local -- prisma migrate deploy --schema=prisma/sys/schema.prisma",
    "setup:test-app": "tsx src/scripts/setup-test-app.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/sensible": "^6.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.9.0",
    "fastify-plugin": "^5.0.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.9.1",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0"
  }
}
